# CapitalOps Frontend — Environment Variables
# Copy this file to .env and fill in your values.

# URL of the Flask backend (e.g. http://localhost:3001)
# If not set, the Express server uses in-memory storage as a fallback.
BACKEND_URL=http://localhost:3001

# Shared secret between the Express proxy and the Flask compat layer.
# Must match COMPAT_API_KEY in the Flask backend's environment.
# If not set, mutation routes on the Flask side are open (dev only).
COMPAT_API_KEY=change-me-in-production

# Express session secret (for user login sessions)
SESSION_SECRET=change-me-in-production

# Optional: Google OAuth (leave blank to disable Google sign-in)
# Get credentials from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
