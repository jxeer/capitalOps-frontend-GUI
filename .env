# CapitalOps Frontend — Environment Variables

# URL of the Flask backend
BACKEND_URL=http://localhost:3000

# Shared secret between the Express proxy and the Flask compat layer
COMPAT_API_KEY=change-me-in-production

# Express session secret
SESSION_SECRET=change-me-in-production

# AWS S3 Configuration (for profile image uploads)
VITE_AWS_BUCKET_URL=http://localhost:3001
